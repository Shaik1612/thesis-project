# Copy this file to:
#   .env.development  → for local Supabase (npm run dev)
#   .env.production   → for hosted Supabase (npm run build, npm run dev:remote)
#
# Shared values (Razorpay test key, etc.) live in .env.

# --- Supabase ---
# For .env.development: point at local Supabase (`npx supabase status` shows the anon key)
#   VITE_SUPABASE_URL=http://127.0.0.1:54321
#   VITE_SUPABASE_ANON_KEY=<local publishable key from `supabase status`>
#
# For .env.production: point at the hosted project
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Razorpay (shared base, lives in .env) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx

# --- App mode flag ---
VITE_APP_ENV=development

# --- Edge Function secrets (set via: supabase secrets set KEY=value) ---
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# RAZORPAY_WEBHOOK_SECRET=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_SMS_FROM=+1234567890
# SUPABASE_SERVICE_ROLE_KEY=
#
# UPI intent for production redirect (optional in sandbox).
# When unset, create-razorpay-order returns upi_intent_url=null and the
# client falls back to the dev "Simulate payment" button.
# UPI_VPA=merchant@upi
# UPI_PAYEE_NAME=DineFlow
#
# Dev/staging only — must NOT be set in production.
# When "true", razorpay-webhook accepts { __simulate: true, razorpay_order_id }
# without HMAC, so the dev "Simulate payment" button can complete the flow.
# ALLOW_RAZORPAY_SIMULATE=true
